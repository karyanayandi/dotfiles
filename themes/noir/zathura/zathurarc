set font "Jetbrains Mono NF 10"
set completion-bg "#0d0b0a"
set completion-fg "#8a8080"
set completion-group-bg "#0c0b0a"
set completion-group-fg "#8a8080"
set completion-highlight-bg "#8a8080"
set completion-highlight-fg "#0d0b0a"
set default-bg "#0d0b0a"
set default-fg "#8a8080"
set inputbar-bg "#0d0b0a"
set inputbar-fg "#949669"
set notification-bg "#949669"
set notification-fg "#0c0b0a"
set notification-error-bg "#916666"
set notification-error-fg "#0c0b0a"
set notification-warning-bg "#8a8080"
set notification-warning-fg "#0c0b0a"
set statusbar-bg "#0c0b0a"
set statusbar-fg "#8a8080"
set statusbar-h-padding 10
set statusbar-v-padding 5
set incremental-search "true"
set highlight-fg rgba(12,11,10,1)
set highlight-color #949669
set highlight-active-color #8a8080
set recolor "true"
set recolor-lightcolor "#a0a4a8"
set recolor-darkcolor "#0c0b0a"
set recolor-keephue "true"
set recolor-reverse-video "true"
set page-padding 10
set show-directories "true"
set show-hidden "true"
set show-recent 5
set guioptions vs
set selection-clipboard clipboard
