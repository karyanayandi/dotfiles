{
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "bunx",
      "args": ["-y", "@upstash/context7-mcp", "--api-key", "{env:CONTEXT7_API_KEY}"],
      "env": {},
      "directTools": true
    },
    "playwriter": {
      "type": "stdio",
      "command": "bunx",
      "args": ["-y", "playwriter@latest"],
      "directTools": true
    },
    "shadcn": {
      "type": "stdio",
      "command": "bunx",
      "args": ["shadcn@latest", "mcp"],
      "directTools": true
    },
    "zai-mcp-server": {
      "type": "stdio",
      "command": "bunx",
      "args": ["zai-mcp-server@latest"],
      "env": {
        "Z_AI_MODE": "ZAI",
        "Z_AI_API_KEY": "{env:Z_AI_API_KEY}"
      },
      "directTools": true
    }
  }
}
