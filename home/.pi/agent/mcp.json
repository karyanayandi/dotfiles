{
  "mcpServers": {
    "context7": {
      "type": "stdio",
      "command": "bash",
      "args": [
        "-c",
        "set -a && source /home/karyana/.env && set +a && exec bunx -y @upstash/context7-mcp"
      ],
      "env": {},
      "directTools": true
    },
    "playwriter": {
      "type": "stdio",
      "command": "bunx",
      "args": ["-y", "playwriter@latest"],
      "directTools": true
    },
    "shadcn": {
      "type": "stdio",
      "command": "bunx",
      "args": ["shadcn@latest", "mcp"],
      "directTools": true
    },
    "codebase-memory-mcp": {
      "type": "stdio",
      "command": "/usr/sbin/codebase-memory-mcp",
      "args": []
    },
    "zai-mcp-server": {
      "type": "stdio",
      "command": "bunx",
      "args": ["zai-mcp-server@latest"],
      "env": {
        "Z_AI_MODE": "ZAI",
        "Z_AI_API_KEY": "${Z_AI_API_KEY}"
      },
      "directTools": true
    }
  }
}
