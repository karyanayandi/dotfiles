{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "compaction": {
    "auto": true
  },
  "lsp": {
    "eslint": {
      "disabled": true
    }
  },
  "mcp": {
    "context7": {
      "enabled": true,
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "playwriter": {
      "command": [
        "bun",
        "x",
        "playwriter@latest"
      ],
      "enabled": true,
      "type": "local"
    },
    "shadcn": {
      "command": [
        "bun",
        "x",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "plugin": [
    "@mohak34/opencode-notifier@latest",
    "@tarquinen/opencode-dcp@latest",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "opencode-swarm"
  ],
  "provider": {
    "ollama": {
      "models": {
        "kimi-k2.5:cloud": {
          "_launch": true,
          "limit": {
            "context": 262144,
            "output": 262144
          },
          "name": "kimi-k2.5:cloud"
        },
        "minimax-m2.5:cloud": {
          "_launch": true,
          "name": "minimax-m2.5:cloud"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    },
    "omniroute": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OmniRoute",
      "options": {
